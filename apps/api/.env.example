PORT=3001

# Supabase PostgreSQL direct connection (Session mode, port 5432)
# Found in: Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase JWT Secret — found in: Supabase Dashboard > Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
