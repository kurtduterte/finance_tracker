        "category_check": {
          "name": "category_check",
          "value": "\"expenses\".\"category\" in ('general','food','transportation','bills','subscriptions','shopping','entertainment')"
        },
        "payment_type_check": {
          "name": "payment_type_check",
          "value": "\"expenses\".\"payment_type\" in ('cash','online')"
        },
        "bank_check": {
