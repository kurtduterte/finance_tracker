          "value": "\"expenses\".\"bank\" in ('gcash','maya','maribank','shopeepay','grabpay','unionbank') or \"expenses\".\"bank\" is null"
        },
        "bank_required_for_online": {
          "name": "bank_required_for_online",
          "value": "(\"expenses\".\"payment_type\" = 'online' and \"expenses\".\"bank\" is not null) or (\"expenses\".\"payment_type\" = 'cash' and \"expenses\".\"bank\" is null)"
        },
